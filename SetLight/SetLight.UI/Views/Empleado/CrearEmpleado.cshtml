@model SetLight.Abstracciones.ModelosParaUI.EmpleadoDto

@{
    ViewBag.Title = "Crear Empleado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow p-4 border-dark rounded-3">
                <h2 class="text-center fw-bold text-black mb-4">Registrar nuevo empleado</h2>

                @using (Html.BeginForm("CrearEmpleado", "Empleado", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.IdEmpleadoGuid)

                    <!-- Foto de Perfil -->
                    <div class="mb-4 text-center">
                        <label for="foto" class="form-label fw-bold d-block">Foto de perfil</label>
                        <input type="file"
                               name="foto"
                               id="foto"
                               class="form-control border-dark"
                               accept="image/*"
                               onchange="previewFoto(this)" />

                        <div class="mt-3 text-center">
                            <img id="preview-img"
                                 src="~/Content/img/placeholder-user.png"
                                 alt="Vista previa"
                                 class="img-thumbnail rounded-circle shadow-sm"
                                 style="width: 120px; height: 120px; object-fit: cover;" />
                        </div>
                    </div>

                    <hr />

                    <!-- Nombre -->
                    <div class="mb-3">
                        @Html.LabelFor(model => model.Nombre, new { @class = "form-label text-black" })
                        @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "form-control border-dark" } })
                        @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger" })
                    </div>

                    <!-- Apellido -->
                    <div class="mb-3">
                        @Html.LabelFor(model => model.Apellido, new { @class = "form-label text-black" })
                        @Html.EditorFor(model => model.Apellido, new { htmlAttributes = new { @class = "form-control border-dark" } })
                        @Html.ValidationMessageFor(model => model.Apellido, "", new { @class = "text-danger" })
                    </div>

                    <!-- Teléfono -->
                    <div class="mb-3">
                        @Html.LabelFor(model => model.TelefonoCelular, new { @class = "form-label text-black" })
                        @Html.EditorFor(model => model.TelefonoCelular, new { htmlAttributes = new { @class = "form-control border-dark" } })
                        @Html.ValidationMessageFor(model => model.TelefonoCelular, "", new { @class = "text-danger" })
                    </div>

                    <!-- Correo -->
                    <div class="mb-3">
                        @Html.LabelFor(model => model.CorreoElectronico, new { @class = "form-label text-black" })
                        @Html.EditorFor(model => model.CorreoElectronico, new { htmlAttributes = new { @class = "form-control border-dark" } })
                        @Html.ValidationMessageFor(model => model.CorreoElectronico, "", new { @class = "text-danger" })
                    </div>

                    <!-- Rol -->
                    <div class="mb-3">
                        @Html.LabelFor(model => model.RolId, new { @class = "form-label text-black" })
                        @Html.DropDownListFor(
                            model => model.RolId,
                            (IEnumerable<SelectListItem>)ViewBag.Roles,
                            "Seleccione un rol",
                            new { @class = "form-select border-dark" }
                        )
                        @Html.ValidationMessageFor(model => model.RolId, "", new { @class = "text-danger" })
                    </div>

                    <!-- Estado -->
                    <div class="mb-3 form-check">
                        @Html.EditorFor(model => model.Estado, new { htmlAttributes = new { @class = "form-check-input" } })
                        @Html.LabelFor(model => model.Estado, new { @class = "form-check-label text-black" })
                        @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                    </div>

                    <hr class="my-4" />

                    <!-- Cédula -->
                    <div class="mb-3">
                        @Html.LabelFor(model => model.Cedula, new { @class = "form-label text-black" })
                        @Html.EditorFor(model => model.Cedula, new { htmlAttributes = new { @class = "form-control border-dark" } })
                        @Html.ValidationMessageFor(model => model.Cedula, "", new { @class = "text-danger" })
                    </div>

                    <!-- Contacto de Emergencia -->
                    <h5 class="mt-4 mb-3 fw-bold text-black">Contacto de Emergencia</h5>

                    <div class="mb-3">
                        @Html.LabelFor(model => model.ContactoEmergenciaNombre, new { @class = "form-label text-black" })
                        @Html.EditorFor(model => model.ContactoEmergenciaNombre, new { htmlAttributes = new { @class = "form-control border-dark" } })
                        @Html.ValidationMessageFor(model => model.ContactoEmergenciaNombre, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(model => model.ContactoEmergenciaTelefono, new { @class = "form-label text-black" })
                        @Html.EditorFor(model => model.ContactoEmergenciaTelefono, new { htmlAttributes = new { @class = "form-control border-dark" } })
                        @Html.ValidationMessageFor(model => model.ContactoEmergenciaTelefono, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(model => model.ContactoEmergenciaParentesco, new { @class = "form-label text-black" })
                        @Html.EditorFor(model => model.ContactoEmergenciaParentesco, new { htmlAttributes = new { @class = "form-control border-dark" } })
                        @Html.ValidationMessageFor(model => model.ContactoEmergenciaParentesco, "", new { @class = "text-danger" })
                    </div>

                    <!-- Información Médica -->
                    <h5 class="mt-4 mb-3 fw-bold text-black">Información Médica</h5>

                    <div class="mb-3">
                        @Html.LabelFor(model => model.TipoSangre, new { @class = "form-label text-black" })
                        @Html.EditorFor(model => model.TipoSangre, new { htmlAttributes = new { @class = "form-control border-dark" } })
                        @Html.ValidationMessageFor(model => model.TipoSangre, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(model => model.Alergias, new { @class = "form-label text-black" })
                        @Html.TextAreaFor(model => model.Alergias, new { @class = "form-control border-dark", rows = 3 })
                        @Html.ValidationMessageFor(model => model.Alergias, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(model => model.InfoMedica, new { @class = "form-label text-black" })
                        @Html.TextAreaFor(model => model.InfoMedica, new { @class = "form-control border-dark", rows = 3 })
                        @Html.ValidationMessageFor(model => model.InfoMedica, "", new { @class = "text-danger" })
                    </div>

                    <!-- Botones -->
                    <div class="text-center mt-4">
                        <input type="submit" value="Registrar" class="btn btn-success fw-semibold me-2 text-white" />
                        @Html.ActionLink("Volver a la lista", "ListarEmpleado", null, new { @class = "btn btn-dark fw-semibold text-white" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 🖼️ Script para previsualizar la imagen
        function previewFoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('preview-img').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
