@model SetLight.Abstracciones.ModelosParaUI.EmpleadoDto
@{
    ViewBag.Title = "Detalles del Empleado";

    var PLACEHOLDER = Url.Content("~/Content/img/placeholder-user.png");
    var foto = string.IsNullOrWhiteSpace(Model.FotoPerfil) ? PLACEHOLDER : Url.Content(Model.FotoPerfil);
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <h2 class="fw-bold text-black text-center mb-4">Detalles del empleado</h2>

            <div class="card shadow p-4 border-dark rounded-3 bg-white">
                <div class="text-center mb-4">
                    <!-- Foto de perfil -->
                    <img src="@foto"
                         alt="Foto de @Model.Nombre"
                         class="img-thumbnail rounded-circle shadow-sm"
                         style="width: 140px; height: 140px; object-fit: cover;" />

                    <div class="mt-2 fw-bold fs-5 text-black">
                        @Model.Nombre @Model.Apellido
                    </div>

                    <!-- Rol -->
                    <div class="text-muted">
                        @(string.IsNullOrWhiteSpace(Model.RolNombre) ? "Sin rol asignado" : Model.RolNombre)
                    </div>
                </div>

                <dl class="row mt-3 mb-0">
                    <dt class="col-sm-3 text-black">Cédula</dt>
                    <dd class="col-sm-9">@Model.Cedula</dd>

                    <dt class="col-sm-3 text-black">Teléfono</dt>
                    <dd class="col-sm-9">@Model.TelefonoCelular</dd>

                    <dt class="col-sm-3 text-black">Correo</dt>
                    <dd class="col-sm-9">@Model.CorreoElectronico</dd>

                    <dt class="col-sm-3 text-black">Estado</dt>
                    <dd class="col-sm-9">
                        @if (Model.Estado)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </dd>
                </dl>

                <hr />

                <dl class="row mt-2 mb-0">
                    <dt class="col-sm-3 text-black">Contacto emergencia</dt>
                    <dd class="col-sm-9">
                        <div><strong>Nombre:</strong> @Model.ContactoEmergenciaNombre</div>
                        <div><strong>Teléfono:</strong> @Model.ContactoEmergenciaTelefono</div>
                        <div><strong>Parentesco:</strong> @Model.ContactoEmergenciaParentesco</div>
                    </dd>

                    <dt class="col-sm-3 text-black">Información médica</dt>
                    <dd class="col-sm-9">
                        <div><strong>Tipo de sangre:</strong> @Model.TipoSangre</div>
                        <div><strong>Alergias:</strong> @Model.Alergias</div>
                        <div><strong>Notas médicas:</strong> @Model.InfoMedica</div>
                    </dd>
                </dl>

                <div class="mt-4 text-center">
                    @Html.ActionLink(
                        "Editar",
                        "Edit",
                        new { id = Model.IdEmpleado },
                        new { @class = "btn btn-warning fw-semibold me-2" }
                    )
                    @Html.ActionLink(
                        "Volver al listado",
                        "ListarEmpleado",
                        null,
                        new { @class = "btn btn-dark fw-semibold text-white" }
                    )
                </div>
            </div>

        </div>
    </div>
</div>
