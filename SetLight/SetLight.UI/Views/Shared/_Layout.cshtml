<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SetLight</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <!-- Bootstrap -->
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/bootstrap.rtl.min.css" rel="stylesheet" />

    <!-- ⬇️BOOTSTRAP ICONS (CDN) -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    <!--estilos -->
    <link href="~/Content/site.css" rel="stylesheet" />

    <link rel="icon" type="image/png" href="~/Content/favicon.png" />

</head>
<body>
    <!-- Si ya pusiste las clases sticky en el nav, déjalas; si no, tu nav normal -->
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm fixed-top sl-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="@Url.Action("Index", "Home")">
                <img src="@Url.Content("~/Content/Logo.jpg")" alt="Logo SetLight" width="150" height="100" class="me-2" />
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (User.IsInRole("Administrador") || User.IsInRole("Colaborador") || User.IsInRole("Tecnico"))
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Equipos", "ListarEquipment", "Equipment", null, new { @class = "nav-link" })
                        </li>
                    }
                    @if (User.IsInRole("Administrador") || User.IsInRole("Colaborador"))
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Clientes", "ListarClient", "Client", null, new { @class = "nav-link" })
                        </li>
}
                    @if (User.IsInRole("Administrador") || User.IsInRole("Colaborador") || User.IsInRole("Tecnico"))
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Ordenes", "Index", "RentalOrder", null, new { @class = "nav-link" })
                        </li>
                    }
                    @if (User.IsInRole("Administrador") || User.IsInRole("Tecnico"))
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Mantenimiento", "Mantenimientos", "ReturnDetails", null, new { @class = "nav-link" })
                        </li>
                    }
                    @if (User.IsInRole("Administrador"))
                    {
                        <li class="nav-item">
                            @Html.ActionLink("Empleado", "ListarEmpleado", "Empleado", null, new { @class = "nav-link" })
                        </li>
                    }
                </ul>
                @Html.Partial("_LoginPartial")
            </div>
        </div>
    </nav>

    <div class="container body-content mt-4">
        @RenderBody()
        <hr />
        <footer class="text-center text-muted py-3">
            <p>&copy; @DateTime.Now.Year - SetLight</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("Scripts", required: false)

    @if (Request.IsAuthenticated)
    {
        <script>
            // URL para cerrar sesión automáticamente
            window.autoLogOffUrl = '@Url.Action("AutoLogOff", "Account")';

        </script>

        <script src="~/Scripts/cliente-detalles.js"></script>


        <script src="~/Scripts/Modals/Seguridad/Temporizador.js"></script>
    }
</body>
</html>
