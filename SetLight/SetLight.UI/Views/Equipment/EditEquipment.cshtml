@model SetLight.Abstracciones.ModelosParaUI.EquipmentDto
@using System.Globalization
@{
    ViewBag.Title = "Editar equipo";

    Func<string, string> Src = (url) =>
    {
        if (string.IsNullOrWhiteSpace(url)) return Url.Content("~/content/img/placeholder-equipment.png");
        return url.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? url : Url.Content(url);
    };
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow p-4 border-dark">
                <h2 class="text-center fw-bold text-black mb-4">Editar equipo</h2>

                @using (Html.BeginForm("Edit", "Equipment", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.EquipmentId)
                    @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                @Html.LabelFor(m => m.EquipmentName, new { @class = "form-label text-black" })
                                @Html.TextBoxFor(m => m.EquipmentName, new
                                {
                                    @class = "form-control border-dark",
                                    data_val = "true",
                                    data_val_required = "El nombre del equipo es obligatorio.",
                                    maxlength = "100",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.EquipmentName, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.Brand, new { @class = "form-label text-black" })
                                @Html.TextBoxFor(m => m.Brand, new
                                {
                                    @class = "form-control border-dark",
                                    data_val = "true",
                                    data_val_required = "La marca es obligatoria.",
                                    maxlength = "60",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.Brand, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.Model, new { @class = "form-label text-black" })
                                @Html.TextBoxFor(m => m.Model, new
                                {
                                    @class = "form-control border-dark",
                                    data_val = "true",
                                    data_val_required = "El modelo es obligatorio.",
                                    maxlength = "60",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.Model, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.SerialNumber, new { @class = "form-label text-black" })
                                @Html.TextBoxFor(m => m.SerialNumber, new
                                {
                                    @class = "form-control border-dark",
                                    data_val = "true",
                                    data_val_required = "El número de serie es obligatorio.",
                                    maxlength = "100",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.SerialNumber, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.Description, new { @class = "form-label text-black" })
                                @Html.TextAreaFor(m => m.Description, new
                                {
                                    @class = "form-control border-dark",
                                    rows = 3,
                                    data_val = "true",
                                    data_val_required = "La descripción es obligatoria.",
                                    maxlength = "500",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.RentalValue, new { @class = "form-label text-black" })
                                @Html.TextBox(
                                    "RentalValue",
                                    (Model != null ? Model.RentalValue.ToString(CultureInfo.InvariantCulture) : ""),
                                    new
                                    {
                                        @class = "form-control border-dark",
                                        type = "number",
                                        step = "0.01",
                                        min = "0.01",
                                        placeholder = "$0.00",
                                        data_val = "true",
                                        data_val_required = "El valor de alquiler es obligatorio.",
                                        data_val_number = "Ingrese un número válido.",
                                        data_val_range = "Debe ser mayor a 0.",
                                        required = "required"
                                    }
                                )
                                @Html.ValidationMessageFor(m => m.RentalValue, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.Stock, new { @class = "form-label text-black" })
                                @Html.TextBoxFor(m => m.Stock, new
                                {
                                    @class = "form-control border-dark",
                                    type = "number",
                                    step = "1",
                                    min = "0",
                                    data_val = "true",
                                    data_val_required = "El campo Stock Disponible es obligatorio.",
                                    data_val_number = "Ingrese un número válido.",
                                    data_val_range = "No puede ser negativo.",
                                    required = "required"
                                })
                                @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-4">
                                @Html.LabelFor(m => m.CategoryId, "Seleccionar categoría", new { @class = "form-label text-black" })
                                <div class="d-flex gap-2">
                                    @Html.DropDownListFor(m => m.CategoryId,
                                        (IEnumerable<SelectListItem>)ViewBag.Categorias,
                                        "-- Seleccione una categoría --",
                                        new
                                        {
                                            @class = "form-control border-dark",
                                            data_val = "true",
                                            data_val_required = "Debe seleccionar una categoría.",
                                            required = "required"
                                        })
                                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#modalEqCategory">Nueva categoría</button>
                                </div>
                                @Html.ValidationMessageFor(m => m.CategoryId, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-2 text-center mb-2">
                                <img id="previewEdit" src="@Src(Model.ImageUrl)"
                                     alt="imagen actual"
                                     style="width:100%; max-height:220px; object-fit:cover; border-radius:8px;" />
                            </div>

                            <div class="mb-2">
                                <label class="form-label text-black">Reemplazar imagen</label>
                                <input type="file" name="nuevaImagen" class="form-control border-dark" accept=".jpg,.jpeg,.png,.webp" />
                                <small class="text-muted">Si seleccionas una nueva imagen, reemplazará a la actual.</small>
                            </div>

                            <div class="form-check my-2">
                                <input class="form-check-input" type="checkbox" name="eliminarImagen" id="eliminarImagen" />
                                <label class="form-check-label" for="eliminarImagen">Eliminar imagen actual</label>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-3">
                        <input type="submit" value="Guardar" class="btn btn-success fw-semibold me-2 text-white" />
                        @Html.ActionLink("Volver al listado", "ListarEquipment", null, new { @class = "btn btn-dark fw-semibold text-white" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEqCategory" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="modal-content-category"></div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/jqueryval")
    @Scripts.Render("~/bundles/jqueryunobtrusive")

    <script src="~/Scripts/Modals/EqCategory/EqCategoryModal.js"></script> <!-- 👈 Aquí agregás tu script -->

    <script>
        $(document).on('change', 'input[name="nuevaImagen"]', function () {
            const file = this.files && this.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (ev) {
                $('#previewEdit').attr('src', ev.target.result);
                $('#eliminarImagen').prop('checked', false);
            };
            reader.readAsDataURL(file);
        });

        $(document).on('change', '#eliminarImagen', function () {
            if (this.checked) {
                $('#previewEdit').attr('src', '@Url.Content("~/content/img/placeholder-equipment.png")');
                $('input[name="nuevaImagen"]').val('');
            }
        });
    </script>
}

