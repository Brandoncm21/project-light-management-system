@model SetLight.UI.Models.ForgotPasswordViewModel

@{
    ViewBag.Title = "Recuperar contraseña";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 85vh;">
    <div class="card p-4 shadow-lg border-dark rounded-3" style="width: 100%; max-width: 500px;">
        <h3 class="text-center mb-3 fw-bold text-dark">
            Recuperar contraseña
        </h3>
        <p class="text-muted text-center">
            Ingrese el correo electrónico con el que está registrado en el sistema.
            Le enviaremos un enlace para restablecer su contraseña.
        </p>
        <hr />

        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { role = "form" }))
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary("", new { @class = "text-danger mb-3" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold text-black" })
                @Html.TextBoxFor(
                    m => m.Email,
                    new
                    {
                        @class = "form-control border-dark",
                        placeholder = "ejemplo@correo.com"
                    })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-dark w-100 fw-semibold">
                Enviar enlace de recuperación
            </button>

            <div class="mt-3 text-center">
                @Html.ActionLink(
                    "Volver a iniciar sesión",
                    "Login",
                    "Account",
                    null,
                    new { @class = "text-decoration-none" })
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
