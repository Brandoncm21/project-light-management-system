@model SetLight.UI.Models.RegisterViewModel
@{
    ViewBag.Title = "Registrarse";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Fondo con logo al 25% -->
<div class="auth-bg">
    <div class="container d-flex align-items-center justify-content-center" style="min-height: 85vh;">
        <div class="card p-4 shadow-lg border-dark rounded-3" style="width: 100%; max-width: 500px;">
            <h3 class="text-center mb-3 fw-bold text-dark">
                Crear cuenta en <span class="text-danger">SetLight</span>
            </h3>
            <p class="text-center text-muted">Complete los datos para registrarse.</p>
            <hr />

            @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary("", new { @class = "text-danger mb-3" })

                <div class="mb-3">
                    @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold text-black" })
                    @Html.TextBoxFor(
                        m => m.Email,
                        new
                        {
                            @class = "form-control border-dark",
                            placeholder = "Correo electrónico"
                        })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Password, new { @class = "form-label fw-semibold text-black" })
                    @Html.PasswordFor(
                        m => m.Password,
                        new
                        {
                            @class = "form-control border-dark",
                            placeholder = "Contraseña"
                        })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label fw-semibold text-black" })
                    @Html.PasswordFor(
                        m => m.ConfirmPassword,
                        new
                        {
                            @class = "form-control border-dark",
                            placeholder = "Confirmar contraseña"
                        })
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn btn-dark w-100 fw-semibold">
                    Registrarse
                </button>

                <div class="mt-3 text-center">
                    @Html.ActionLink(
                        "¿Ya tienes cuenta? Inicia sesión",
                        "Login",
                        "Account",
                        null,
                        new { @class = "text-decoration-none" })
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
