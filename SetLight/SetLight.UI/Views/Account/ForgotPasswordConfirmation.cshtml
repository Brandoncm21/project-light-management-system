@{
    ViewBag.Title = "Correo enviado";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 85vh;">
    <div class="card p-4 shadow-lg border-dark rounded-3 text-center" style="width: 100%; max-width: 500px;">
        <h3 class="mb-3 fw-bold text-dark">@ViewBag.Title</h3>

        <p class="lead text-dark">
            Si el correo ingresado está registrado en el sistema,
            hemos enviado un enlace para restablecer tu contraseña.
        </p>

        <p class="text-muted">
            Revisa tu bandeja de entrada y también la carpeta de spam o correo no deseado.
        </p>

        @Html.ActionLink(
            "Volver al inicio de sesión",
            "Login",
            "Account",
            null,
            new { @class = "btn btn-dark mt-3 fw-semibold" }
        )
    </div>
</div>
