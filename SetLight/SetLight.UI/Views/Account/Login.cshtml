@using SetLight.UI.Models
@model LoginViewModel

@{
    ViewBag.Title = "Iniciar sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 85vh;">
    <div class="card p-4 shadow-lg border-dark rounded-3" style="width: 100%; max-width: 500px;">
        <h3 class="text-center mb-3 fw-bold text-dark">
            Bienvenido a <span class="text-danger">SetLight</span>
        </h3>
        <p class="text-center text-muted mb-3">Utilice una cuenta local para iniciar sesión.</p>
        <hr />

        @* 🔐 Mensaje cuando el filtro lo sacó por cuenta desactivada *@
        @if (ViewBag.CuentaDesactivada != null)
        {
            <div class="alert alert-warning text-center">
                @ViewBag.CuentaDesactivada
            </div>
        }

        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Email, htmlAttributes: new { @class = "form-label fw-semibold text-black" })
                @Html.TextBoxFor(
                    m => m.Email,
                    new
                    {
                        @class = "form-control border-dark",
                        placeholder = "Correo electrónico"
                    })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.Password, htmlAttributes: new { @class = "form-label fw-semibold text-black" })
                @Html.PasswordFor(
                    m => m.Password,
                    new
                    {
                        @class = "form-control border-dark",
                        placeholder = "Contraseña"
                    })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3 form-check">
                @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.RememberMe, new { @class = "form-check-label text-black" })
            </div>

            <button type="submit" class="btn btn-dark w-100 fw-semibold">
                Iniciar sesión
            </button>

            <div class="mt-3 text-center">
                @Html.ActionLink(
                    "Registrarse como usuario nuevo",
                    "Register",
                    "Account",
                    null,
                    new { @class = "text-decoration-none me-2" })

                @Html.ActionLink(
                    "¿Olvidaste tu contraseña?",
                    "ForgotPassword",
                    "Account",
                    null,
                    new { @class = "text-decoration-none" })
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
