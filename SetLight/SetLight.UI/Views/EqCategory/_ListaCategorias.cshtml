@model IEnumerable<SetLight.Abstracciones.ModelosParaUI.EqCategoryDto>

<table class="table table-striped table-hover mb-0">
    <thead>
        <tr>
            <th>Nombre de la categoría</th>
            <th style="width: 120px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var c in Model)
            {
                <tr>
                    <td>@c.CategoryName</td>
                    <td>
                        <button type="button"
                                class="btn btn-sm btn-primary btn-editar-cat"
                                data-id="@c.CategoryId">
                            Editar
                        </button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="2" class="text-center text-muted">
                    No hay categorías registradas.
                </td>
            </tr>
        }
    </tbody>
</table>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center mb-0">

            <!-- ⏮ Primera -->
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="?page=1" tabindex="-1">&laquo;</a>
            </li>

            <!-- ◀ Anterior -->
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="?page=@(ViewBag.CurrentPage - 1)" tabindex="-1">&lsaquo;</a>
            </li>

            <!-- 🔢 Números -->
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i">@i</a>
                </li>
            }

            <!-- ▶ Siguiente -->
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" href="?page=@(ViewBag.CurrentPage + 1)" tabindex="-1">&rsaquo;</a>
            </li>

            <!-- ⏭ Última -->
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" href="?page=@ViewBag.TotalPages" tabindex="-1">&raquo;</a>
            </li>

        </ul>
    </nav>
}
