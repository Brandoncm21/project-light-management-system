@model SetLight.Entidades.Maintenance

@{
    ViewBag.Title = "Editar mantenimiento";

    // ✅ Nombre de equipo seguro
    var nombreEquipo = (Model.Equipment != null &&
                        !string.IsNullOrWhiteSpace(Model.Equipment.EquipmentName))
        ? Model.Equipment.EquipmentName
        : "(Equipo sin nombre)";

    string tipo = "—";
    switch (Model.MaintenanceType)
    {
        case 1: tipo = "Revisión por daño"; break;
        case 2: tipo = "Reparación mayor"; break;
        case 3: tipo = "Mantenimiento preventivo"; break;
    }

    string estadoTexto = "Desconocido";
    string estadoClase = "badge bg-secondary";

    switch (Model.MaintenanceStatus)
    {
        case 0:
            estadoTexto = "Pendiente";
            estadoClase = "badge bg-warning text-dark";
            break;
        case 1:
            estadoTexto = "Finalizado";
            estadoClase = "badge bg-success";
            break;
        case 2:
            estadoTexto = "Cancelado";
            estadoClase = "badge bg-secondary";
            break;
    }
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">

            <h2 class="fw-bold text-black text-center mb-4">
                Editar mantenimiento
            </h2>

            <div class="card shadow p-4 border-dark rounded-3">
                <div class="card-body">
                    <!-- Encabezado del mantenimiento -->
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h4 class="mb-1">
                                @nombreEquipo
                            </h4>
                            <div class="text-muted small">
                                <span class="me-3">
                                    <i class="bi bi-tools me-1"></i>@tipo
                                </span>
                                <span>
                                    <i class="bi bi-calendar-event me-1"></i>
                                    Inicio: @Model.StartDate.ToString("dd/MM/yyyy HH:mm")
                                </span>
                                @if (Model.EndDate.HasValue)
                                {
                                    <span class="ms-3">
                                        <i class="bi bi-flag me-1"></i>
                                        Fin: @Model.EndDate.Value.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                }
                            </div>
                        </div>
                        <span class="@estadoClase">@estadoTexto</span>
                    </div>

                    <hr />

                    @using (Html.BeginForm("EditarMantenimiento", "ReturnDetails", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.MaintenanceId)

                        <div class="row g-3">
                            <!-- Comentarios -->
                            <div class="col-12">
                                <label class="form-label fw-semibold">Comentarios</label>
                                @Html.TextArea(
                                    "comments",
                                    Model.Comments,
                                    new
                                    {
                                        @class = "form-control border-dark",
                                        rows = 4,
                                        placeholder = "Describe el trabajo realizado o notas adicionales..."
                                    }
                                )
                            </div>

                            <!-- Costo -->
                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Costo ($)</label>
                                @Html.TextBox(
                                    "cost",
                                    Model.Cost?.ToString("N2"),
                                    new
                                    {
                                        @class = "form-control border-dark",
                                        type = "number",
                                        step = "0.01",
                                        min = "0"
                                    }
                                )
                                <small class="text-muted">Si no aplica, puedes dejarlo en blanco.</small>
                            </div>

                            <!-- Evidencia actual -->
                            <div class="col-md-8">
                                <label class="form-label fw-semibold">Evidencia actual</label>

                                <div class="border rounded p-2 bg-light">
                                    @if (!string.IsNullOrEmpty(Model.EvidencePath))
                                    {
                                        var extension = System.IO.Path.GetExtension(Model.EvidencePath).ToLower();
                                        if (extension == ".jpg" || extension == ".jpeg" || extension == ".png" || extension == ".gif" || extension == ".webp")
                                        {
                                            <img src="@Url.Content(Model.EvidencePath)"
                                                 alt="Evidencia"
                                                 class="img-fluid rounded shadow-sm"
                                                 style="max-height: 250px; object-fit: contain;" />
                                        }
                                        else
                                        {
                                            <a href="@Url.Content(Model.EvidencePath)"
                                               target="_blank"
                                               class="btn btn-sm btn-outline-primary">
                                                Ver archivo actual
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">— Sin evidencia registrada —</span>
                                    }
                                </div>
                            </div>

                            <!-- Nueva evidencia -->
                            <div class="col-12">
                                <label class="form-label fw-semibold">Reemplazar evidencia</label>
                                <input type="file" name="evidenceFile" class="form-control border-dark" />
                                <small class="text-muted">
                                    Opcional. Si subes un archivo, se reemplazará la evidencia anterior.
                                </small>
                            </div>
                        </div>

                        <hr class="mt-4" />

                        <!-- Botones abajo, centrados -->
                        <div class="text-center mt-2">
                            @Html.ActionLink(
                                "Volver a mantenimientos",
                                "Mantenimientos",
                                "ReturnDetails",
                                null,
                                new { @class = "btn btn-dark fw-semibold text-white me-2" }
                            )

                            <button type="submit" class="btn btn-success fw-semibold">
                                <i class="bi bi-save me-1"></i>Guardar cambios
                            </button>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
