@model List<SetLight.Abstracciones.ModelosParaUI.ReturnDetailsDto>

@{
    ViewBag.Title = "Detalles de Devolución";

    // 👇 Tomamos los valores del ViewBag de forma segura
    string clientName = ViewBag.ClientName as string;
    string clientIdStr = ViewBag.ClientId != null ? ViewBag.ClientId.ToString() : null;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow p-4 border-dark">
                <h2 class="text-center fw-bold text-black mb-4">
                    Detalles de devolución - Orden @ViewBag.OrderId
                </h2>

                <!-- Resumen de la orden -->
                <div class="mb-4">
                    <h5 class="fw-bold text-dark mb-3">Resumen de la orden</h5>
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr>
                                <th style="width: 25%;">Cliente</th>
                                <td>
                                    @if (!string.IsNullOrEmpty(clientName))
                                    {
                                        // Si también tenemos ClientId, hacemos link + modal reutilizable
                                        if (!string.IsNullOrEmpty(clientIdStr))
                                        {
                                            <a href="#"
                                               data-bs-toggle="modal"
                                               data-bs-target="@("#cltModal_" + clientIdStr)">
                                                @clientName
                                            </a>

                                            @Html.Action("ModalDetallesCliente", "Client", new { id = clientIdStr })
                                        }
                                        else
                                        {
                                            @clientName
                                        }
                                    }
                                    else
                                    {
                                        @Html.Raw("N/D")
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Fecha de inicio</th>
                                <td>
                                    @(ViewBag.StartDate != null
                                        ? ((DateTime)ViewBag.StartDate).ToShortDateString()
                                        : "N/D")
                                </td>
                            </tr>
                            <tr>
                                <th>Fecha de fin</th>
                                <td>
                                    @(ViewBag.EndDate != null
                                        ? ((DateTime)ViewBag.EndDate).ToShortDateString()
                                        : "N/D")
                                </td>
                            </tr>
                            <tr>
                                <th>Estado de la orden</th>
                                <td>@(ViewBag.StatusTexto ?? "N/D")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                @if (!Model.Any())
                {
                    <div class="alert alert-info text-center">
                        No hay devoluciones registradas para esta orden.
                    </div>
                }
                else
                {
                    <div class="table-responsive mt-3">
                        <h5 class="fw-bold text-dark mb-3">Historial de devoluciones</h5>
                        <table class="table table-bordered table-hover text-center align-middle">
                            <thead class="table-dark text-white">
                                <tr>
                                    <th>Equipo</th>

                                    <!-- ✅ NUEVO -->
                                    <th>Precio unitario</th>

                                    <th>Fecha de devolución</th>
                                    <th>¿Devuelto?</th>
                                    <th>¿Requiere mantenimiento?</th>
                                    <th>Observaciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.EquipmentName</td>

                                        <!-- ✅ NUEVO -->
                                        <td>$@item.UnitRentalPrice.ToString("N2")</td>

                                        <td>@item.ReturnDate.ToShortDateString()</td>
                                        <td>@(item.IsReturned ? "Sí" : "No")</td>
                                        <td>@(item.RequiresMaintenance ? "Sí" : "No")</td>
                                        <td class="text-start">@item.ConditionReport</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="text-center mt-3">
                    @Html.ActionLink(
                        "Volver al listado de órdenes",
                        "Index",
                        "RentalOrder",
                        null,
                        new { @class = "btn btn-dark fw-semibold text-white" }
                    )
                </div>
            </div>
        </div>
    </div>
</div>
