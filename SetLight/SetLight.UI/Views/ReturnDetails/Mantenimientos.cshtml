@model PagedList.IPagedList<SetLight.Entidades.Maintenance>
@using System.Globalization
@using PagedList.Mvc
@using PagedList

@{
    ViewBag.Title = "Mantenimientos";

    var us = CultureInfo.GetCultureInfo("en-US");
    var PLACEHOLDER = Url.Content("~/Content/img/placeholder-equipment.png");

    Func<SetLight.Entidades.Maintenance, string> GetImg = m =>
    {
        var raw = m.Equipment != null ? m.Equipment.ImageUrl : null;
        if (string.IsNullOrWhiteSpace(raw)) return PLACEHOLDER;
        return Url.Content(raw);
    };

    Func<int, string> Tipo = t =>
        t == 1 ? "Revisión por daño" :
        t == 2 ? "Reparación mayor" :
        t == 3 ? "Mantenimiento preventivo" :
        "—";

    Func<int, string> Estado = s =>
        s == 0 ? "Pendiente" :
        s == 1 ? "Finalizado" :
        s == 2 ? "Cancelado" :
        "Desconocido";

    Func<int, string> EstadoClase = s =>
        s == 0 ? "mant-status-pendiente" :
        s == 1 ? "mant-status-finalizado" :
        s == 2 ? "mant-status-cancelado" :
        "mant-status-desconocido";
}

<div class="container mt-5">

    <!-- Título + botones -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-black mb-0">Mantenimientos</h2>

        <div class="d-flex gap-2">
            @Html.ActionLink(
                "Equipos faltantes",
                "Faltantes",
                "ReturnDetails",
                null,
                new { @class = "btn btn-pill-light" }
            )

            @Html.ActionLink(
                "+ Registrar mantenimiento manual",
                "CreateMaintenance",
                "ReturnDetails",
                null,
                new { @class = "btn btn-pill-success" }
            )
        </div>
    </div>

    <!-- Filtros -->
    <div class="card p-3 mb-4">
        <form method="get" class="row g-2 align-items-end">
            <!-- Equipo -->
            <div class="col-md-3">
                <label class="form-label text-black">Equipo</label>
                <input type="text"
                       name="equipo"
                       placeholder="Buscar equipo..."
                       value="@ViewBag.FiltroEquipo"
                       class="form-control border-dark" />
            </div>

            <!-- Tipo -->
            <div class="col-md-3">
                <label class="form-label text-black">Tipo</label>
                <select name="tipo" class="form-select border-dark">
                    <option value="">-- Todos --</option>
                    <option value="1" @(ViewBag.FiltroTipo == 1 ? "selected" : "")>Revisión por daño</option>
                    <option value="2" @(ViewBag.FiltroTipo == 2 ? "selected" : "")>Reparación mayor</option>
                    <option value="3" @(ViewBag.FiltroTipo == 3 ? "selected" : "")>Mantenimiento preventivo</option>
                </select>
            </div>

            <!-- Fecha desde -->
            <div class="col-md-2">
                <label class="form-label text-black">Desde</label>
                <input type="date"
                       name="desde"
                       value="@ViewBag.FiltroDesde"
                       class="form-control border-dark" />
            </div>

            <!-- Fecha hasta -->
            <div class="col-md-2">
                <label class="form-label text-black">Hasta</label>
                <input type="date"
                       name="hasta"
                       value="@ViewBag.FiltroHasta"
                       class="form-control border-dark" />
            </div>

            <!-- Estado -->
            <div class="col-md-2">
                <label class="form-label text-black">Estado</label>
                <select name="estado" class="form-select border-dark">
                    <option value="">-- Todos --</option>
                    <option value="0" @(ViewBag.FiltroEstado == 0 ? "selected" : "")>Pendiente</option>
                    <option value="1" @(ViewBag.FiltroEstado == 1 ? "selected" : "")>Finalizado</option>
                    <option value="2" @(ViewBag.FiltroEstado == 2 ? "selected" : "")>Cancelado</option>
                </select>
            </div>

            <!-- Botones -->
            <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                <button type="submit" class="btn btn-dark">
                    <i class="bi bi-funnel me-1"></i>Filtrar
                </button>
                <a href="@Url.Action("Mantenimientos","ReturnDetails")"
                   class="btn btn-outline-secondary">
                    Limpiar
                </a>
            </div>
        </form>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- GRID DE CARDS -->
    <div class="maint-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var m in Model)
            {
                var nombreEquipo = m.Equipment != null && !string.IsNullOrWhiteSpace(m.Equipment.EquipmentName)
                    ? m.Equipment.EquipmentName
                    : "(Sin nombre)";

                <div class="maint-card">
                    <img class="maint-photo"
                         src="@GetImg(m)"
                         alt="Foto @nombreEquipo"
                         onerror="this.onerror=null;this.src='@PLACEHOLDER';" />

                    <div class="maint-info">
                        <div class="maint-name">
                            <div class="text-muted fw-bold" style="font-size: 0.95rem;">
                                Mantenimiento #@m.MaintenanceId
                            </div>
                            @nombreEquipo
                        </div>


                        <div class="maint-chips">
                            <span class="chip">@Tipo(m.MaintenanceType)</span>

                            <span class="chip">
                                <strong>Inicio:</strong> @m.StartDate.ToString("dd/MM/yyyy HH:mm")
                            </span>

                            <span class="chip">
                                <strong>Fin:</strong>
                                @(m.EndDate.HasValue ? m.EndDate.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                            </span>

                            <span class="chip @EstadoClase(m.MaintenanceStatus)">
                                @Estado(m.MaintenanceStatus)
                            </span>
                        </div>

                        <div class="maint-footer">
                            <span class="maint-cost">
                                @(m.Cost.HasValue
                                    ? m.Cost.Value.ToString("C2", us)
                                    : "Sin costo")
                            </span>

                            <div class="btn-group" role="group">
                                <!-- Ver detalles -->
                                <a href="@Url.Action("DetallesMantenimiento","ReturnDetails", new { id = m.MaintenanceId })"
                                   class="btn btn-dark btn-sm rounded-circle"
                                   title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <!-- Editar solo si está pendiente -->
                                @if (m.MaintenanceStatus == 0)
                                {
                                    <a href="@Url.Action("EditarMantenimiento","ReturnDetails", new { id = m.MaintenanceId })"
                                       class="btn btn-warning btn-sm rounded-circle ms-1"
                                       title="Editar mantenimiento (activo)">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn btn-warning btn-sm rounded-circle ms-1 disabled"
                                            title="Solo se puede editar si el mantenimiento está activo"
                                            disabled>
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                }

                                <!-- Finalizar solo si está pendiente -->
                                @if (m.MaintenanceStatus == 0)
                                {
                                    <a href="@Url.Action("Finalize","ReturnDetails", new { id = m.MaintenanceId })"
                                       class="btn btn-success btn-sm rounded-circle ms-1"
                                       title="Finalizar mantenimiento">
                                        <i class="bi bi-check2"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-muted">
                No hay mantenimientos registrados con los filtros actuales.
            </div>
        }
    </div>

    <!-- Paginación (igual estilo que otros módulos) -->
    @if (Model != null && Model.Any())
    {
        <div class="mt-4 d-flex justify-content-center">
            @Html.PagedListPager(
                Model,
                page => Url.Action(
                    "Mantenimientos",
                    "ReturnDetails",
                    new
                    {
                        page,
                        equipo = ViewBag.FiltroEquipo,
                        tipo = ViewBag.FiltroTipo,
                        estado = ViewBag.FiltroEstado,
                        desde = ViewBag.FiltroDesde,
                        hasta = ViewBag.FiltroHasta
                    }
                ),
                new PagedListRenderOptions
                {
                    DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                    DisplayLinkToLastPage = PagedListDisplayMode.Always,
                    DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                    DisplayLinkToNextPage = PagedListDisplayMode.Always,
                    MaximumPageNumbersToDisplay = 12,
                    UlElementClasses = new[] { "pagination" }
                }
            )
        </div>
    }
</div>

<style>
    /* =========================
       Paginación (la tuya)
    ========================== */
    .pagination {
        display: flex !important;
        justify-content: center !important;
        padding-left: 0;
        list-style: none;
        gap: 6px;
    }

        .pagination li a,
        .pagination li span {
            color: black !important;
            margin: 0 5px;
            border-radius: 4px;
            padding: 5px 10px;
            display: inline-block;
            text-decoration: none;
        }

        .pagination li.active span {
            background-color: #e9ecef !important;
            color: black !important;
            font-weight: bold;
        }

        .pagination li a:hover {
            background-color: #f0f0f0;
            color: black !important;
        }

    /* =========================
       Botones pill (los tuyos)
    ========================== */
    .btn-pill-light {
        background-color: #e5e7eb;
        border: 1px solid #d1d5db;
        color: #111827;
        padding: 0.45rem 1.4rem;
        border-radius: 6px;
        font-weight: 600;
        box-shadow: 0 2px 4px rgba(0,0,0,.04);
        text-decoration: none;
        display: inline-block;
    }

        .btn-pill-light:hover {
            background-color: #d4d4d8;
            border-color: #9ca3af;
            color: #111827;
        }

    .btn-pill-success {
        background-color: #15803d;
        border: 1px solid #15803d;
        color: #ffffff;
        padding: 0.45rem 1.7rem;
        border-radius: 6px;
        font-weight: 600;
        box-shadow: 0 2px 4px rgba(0,0,0,.08);
        text-decoration: none;
        display: inline-block;
    }

        .btn-pill-success:hover {
            background-color: #166534;
            border-color: #166534;
            color: #ffffff;
        }

    /* =========================
       GRID + CARDS (FALTABA)
       Estilo tipo "Faltantes"
    ========================== */
    .maint-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 22px;
        align-items: stretch;
        margin-top: 10px;
    }

    @@media (max-width: 1200px) {
        .maint-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .maint-grid {
            grid-template-columns: 1fr;
        }
    }

    .maint-card {
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 12px 25px rgba(15,23,42,.08);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: transform .12s ease, box-shadow .12s ease;
    }

        .maint-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 32px rgba(15,23,42,.12);
        }

    /* 👇 Imagen igual a "Faltantes": altura fija y se ve completa sin recorte raro */
    .maint-photo {
        width: 100%;
        height: 260px;            /* igual que faltantes */
        object-fit: cover;        /* si querés CERO recorte: cambia a contain */
        object-position: center;
        background: #f3f4f6;
        display: block;
    }

    .maint-info {
        padding: 16px 20px 18px 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex: 1;
    }

    .maint-name {
        font-size: 1rem;
        font-weight: 800;
        line-height: 1.3;
        min-height: 2.6em;
    }

    .maint-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .chip {
        border-radius: 999px;
        padding: .22rem .55rem;
        font-size: .78rem;
        font-weight: 600;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        color: #4b5563;
        white-space: nowrap;
    }

    /* Estados */
    .mant-status-pendiente {
        background: #ffedd5 !important;
        border-color: #fb923c !important;
        color: #9a3412 !important;
    }

    .mant-status-finalizado {
        background: #dcfce7 !important;
        border-color: #22c55e !important;
        color: #166534 !important;
    }

    .mant-status-cancelado {
        background: #e5e7eb !important;
        border-color: #9ca3af !important;
        color: #111827 !important;
    }

    .mant-status-desconocido {
        background: #f3f4f6 !important;
        border-color: #e5e7eb !important;
        color: #374151 !important;
    }

    .maint-footer {
        margin-top: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .maint-cost {
        font-size: 1.1rem;
        font-weight: 800;
        color: #111827;
    }

    /* Botones redondos consistentes */
    .btn-group .btn.rounded-circle {
        width: 42px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }

    .btn-group .btn i {
        pointer-events: none;
        font-size: 1.05rem;
    }
</style>
