@model SetLight.Entidades.Maintenance

@{
    ViewBag.Title = "Finalizar mantenimiento";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card shadow p-4 border-dark rounded-3 bg-white">
                <h2 class="text-center mb-4 text-dark fw-bold">Finalizar mantenimiento</h2>

                @using (Html.BeginForm(
                           "FinalizarMantenimiento",
                           "ReturnDetails",
                           FormMethod.Post,
                           new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()

                    @* Id del mantenimiento *@
                    @Html.HiddenFor(m => m.MaintenanceId)

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-black">Equipo</label>
                        <p class="form-control-plaintext fw-semibold">
                            @(Model.Equipment != null
                                ? Model.Equipment.EquipmentName
                                : "(Sin nombre de equipo)")
                        </p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-black">Comentarios</label>
                        @Html.TextArea(
                            "comments",
                            Model.Comments,@* muestra comentarios existentes si los hubiera *@
new
{
@class = "form-control border-dark",
rows = 3,
placeholder = "Notas finales del mantenimiento, trabajos realizados, etc."
})
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-black">Costo</label>
                        @Html.TextBox(
                            "cost",
                            Model.Cost.HasValue ? Model.Cost.Value.ToString("0.##") : "",
                            new
                            {
                                @class = "form-control border-dark",
                                type = "number",
                                step = "0.01",
                                min = "0"
                            })
                        <small class="text-muted">Si no aplica, puedes dejarlo en blanco.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-black">Evidencia (opcional)</label>
                        <input type="file" name="evidenceFile" class="form-control border-dark" />
                        <small class="text-muted">
                            Puedes adjuntar una foto, PDF u otro archivo con la evidencia del trabajo realizado.
                        </small>
                    </div>

                    <div class="mt-4 text-center">
                        <button type="submit" class="btn btn-success px-4 fw-semibold me-2">
                            Guardar y finalizar
                        </button>
                        @Html.ActionLink(
                            "Cancelar",
                            "Mantenimientos",
                            "ReturnDetails",
                            null,
                            new { @class = "btn btn-dark fw-semibold text-white" }
                        )
                    </div>
                }
            </div>

        </div>
    </div>
</div>
