@model List<SetLight.Entidades.Dto.MaintenanceDto>

@{
    ViewBag.Title = "Equipos faltantes / no devueltos";

    // Imagen por defecto
    var PLACEHOLDER = Url.Content("~/Content/img/placeholder-equipment.png");

    // Igual que en inventario: normaliza la ruta de la imagen
    Func<string, string> Src = (raw) =>
    {
        if (string.IsNullOrWhiteSpace(raw)) return PLACEHOLDER;

        var url = raw.Trim();

        if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
            url.StartsWith("//") ||
            url.StartsWith("data:", StringComparison.OrdinalIgnoreCase))
            return url;

        url = url.Replace("\\", "/");

        if (url.StartsWith("~/")) return Url.Content(url);
        if (url.StartsWith("/")) return Url.Content("~" + url);

        return Url.Content("~/" + url.TrimStart('/'));
    };

    // Helper para el texto del estado
    Func<int, string> TextoEstado = (estado) =>
    {
        switch (estado)
        {
            case 0: return "Pendiente";
            case 1: return "Finalizado";
            default: return "Desconocido";
        }
    };
}

<style>
    /* ==== Layout general, igual que inventario ==== */
    .inv-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .inv-title {
        margin: 0;
        font-weight: 800;
        font-size: 1.6rem;
    }

    .equip-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0,1fr));
        gap: 22px;
        align-items: stretch;
    }

    @@media (max-width: 1200px) {
        .equip-grid {
            grid-template-columns: repeat(2, minmax(0,1fr));
        }
    }

    @@media (max-width: 768px) {
        .equip-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ==== Card estilo inventario ==== */
    .equip-card {
        background: #ffffff;
        border-radius: 24px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 12px 25px rgba(15,23,42,.08);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: transform .12s ease, box-shadow .12s ease;
    }

        .equip-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 32px rgba(15,23,42,.12);
        }

    .equip-photo {
        width: 100%;
        height: 260px;
        object-fit: cover;
        background: #f3f4f6;
        display: block;
    }

    .equip-body {
        padding: 16px 20px 18px 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex: 1;
    }

    .equip-name {
        font-size: 1rem;
        font-weight: 800;
        line-height: 1.3;
        min-height: 2.6em;
        margin-bottom: 4px;
    }

    .equip-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 4px;
    }

    .tag-pill {
        border-radius: 999px;
        padding: .22rem .55rem;
        font-size: .78rem;
        font-weight: 600;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        color: #4b5563;
        white-space: nowrap;
    }

    .tag-pill-warning {
        background: #fef3c7;
        border-color: #facc15;
        color: #92400e;
    }

    .tag-pill-estado-pendiente {
        background: #ffedd5;
        border-color: #fb923c;
        color: #9a3412;
    }

    .tag-pill-estado-finalizado {
        background: #dcfce7;
        border-color: #22c55e;
        color: #166534;
    }

    .equip-bottom {
        margin-top: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .equip-price {
        font-size: 1.1rem;
        font-weight: 800;
        color: #111827;
    }

    .equip-price-label {
        font-size: .8rem;
        color: #6b7280;
        display: block;
        margin-bottom: 2px;
    }

    /* ==== Botones redondos como en inventario ==== */
    .btn-circle-sm {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border-width: 0;
        font-size: 1.1rem;
    }

    .btn-circle-yellow {
        background: #facc15;
        color: #1f2933;
    }

    .btn-circle-dark {
        background: #111827;
        color: #f9fafb;
    }

    .btn-circle-gray {
        background: #e5e7eb;
        color: #111827;
    }

    .btn-circle-sm i {
        pointer-events: none;
    }

    .btn-circle-sm:hover {
        opacity: .9;
    }
</style>

<div class="container mt-4 mb-5" style="max-width: 1200px;">
    <div class="inv-header">
        <h2 class="inv-title text-dark">Equipos faltantes / no devueltos</h2>

        @Html.ActionLink(
            "Volver a mantenimientos",
            "Mantenimientos",
            "ReturnDetails",
            null,
            new { @class = "btn btn-secondary" }
        )
    </div>

    @* FILTROS: Cliente, Equipo, Cantidad faltante, Estado *@
    @using (Html.BeginForm("Faltantes", "ReturnDetails", FormMethod.Get))
    {
        <div class="card p-3 mb-4 border-0 shadow-sm">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Cliente</label>
                    <input type="text"
                           name="cliente"
                           value="@ViewBag.FiltroCliente"
                           class="form-control"
                           placeholder="Nombre del cliente" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Equipo</label>
                    <input type="text"
                           name="equipo"
                           value="@ViewBag.FiltroEquipo"
                           class="form-control"
                           placeholder="Nombre del equipo" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Cantidad faltante (mín.)</label>
                    <input type="number"
                           name="cantidadMin"
                           value="@ViewBag.FiltroCantidadMin"
                           min="1"
                           class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    @Html.DropDownList(
                        "estado",
                        (IEnumerable<SelectListItem>)ViewBag.Estados ?? new List<SelectListItem>(),
                        "Todos",
                        new { @class = "form-select" }
                    )
                </div>

                <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                    <button type="submit" class="btn btn-dark">
                        <i class="bi bi-funnel me-1"></i> Filtrar
                    </button>
                    <a href="@Url.Action("Faltantes","ReturnDetails")"
                       class="btn btn-outline-secondary">
                        Limpiar
                    </a>
                </div>
            </div>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="equip-grid">
            @foreach (var item in Model)
            {
                var img = Src(item.ImageUrl);

                <div class="equip-card">
                    <img class="equip-photo"
                         src="@img"
                         alt="Foto @item.EquipmentName"
                         onerror="this.onerror=null;this.src='@PLACEHOLDER';" />

                    <div class="equip-body">
                        <div class="equip-name">
                            @item.EquipmentName
                        </div>

                        <div class="equip-tags">
                            @* Orden *@
                            @if (item.OrderId.HasValue)
                            {
                                <span class="tag-pill">
                                    @Html.ActionLink(
                                        "#" + item.OrderId.Value,
                                        "DetallesDevolucion",
                                        "ReturnDetails",
                                        new { orderId = item.OrderId.Value },
                                        new { @class = "text-decoration-none" }
                                    )
                                </span>
                            }
                            else
                            {
                                <span class="tag-pill text-muted">Orden N/D</span>
                            }

                            @* Cliente *@
                            <span class="tag-pill">
                                @(string.IsNullOrEmpty(item.ClientName)
                                    ? "Cliente desconocido"
                                    : item.ClientName)
                            </span>

                            @* Cantidad faltante *@
                            <span class="tag-pill tag-pill">
                                Falt: @item.Cantidad
                            </span>

                            @* Estado *@
                            <span class="tag-pill @(item.MaintenanceStatus == 0 ? "tag-pill-estado-pendiente" : "tag-pill-estado-finalizado")">
                                @TextoEstado(item.MaintenanceStatus)
                            </span>
                        </div>

                        <div class="equip-bottom">
                            <div>
                                <span class="equip-price-label">Costo de reposición</span>
                                @if (item.Cost.HasValue)
                                {
                                    <span class="equip-price">@item.Cost.Value.ToString("C")</span>
                                }
                                else
                                {
                                    <span class="text-muted">Sin definir</span>
                                }
                            </div>

                            <div class="d-flex gap-2">
                                @* Editar *@
                                <a href="@Url.Action("EditFaltante", "ReturnDetails",
                                                     new { id = item.MaintenanceId })"
                                   class="btn-circle-sm btn-circle-yellow"
                                   title="Editar">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                @* Detalles *@
                                <a href="@Url.Action("DetallesFaltante", "ReturnDetails",
                                                     new { id = item.MaintenanceId })"
                                   class="btn-circle-sm btn-circle-dark"
                                   title="Detalles">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @* Finalizar *@
                                @if (item.MaintenanceStatus == 0)
                                {
                                    using (Html.BeginForm("FinalizarFaltante", "ReturnDetails",
                                                           new { id = item.MaintenanceId },
                                                           FormMethod.Post,
                                                           new { @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm btn-success btn-circle-sm"
                                                title="Finalizar"
                                                onclick="return confirm('¿Marcar este faltante como finalizado?');">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info mt-3">
            No hay registros de equipos faltantes en este momento.
        </div>
    }
</div>
