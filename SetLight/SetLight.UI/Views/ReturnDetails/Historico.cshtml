@model List<SetLight.Entidades.Maintenance>

@{
    ViewBag.Title = "Histórico de Mantenimientos";
}

<h2>Histórico de Mantenimientos</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Equipo</th>
            <th>Inicio</th>
            <th>Fin</th>
            <th>Tipo</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@(m.Equipment != null ? m.Equipment.EquipmentName : "—")</td>
                <td>@m.StartDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    @Html.Raw(
                        m.EndDate.HasValue
                        ? m.EndDate.Value.ToString("dd/MM/yyyy HH:mm")
                        : "<em>En curso</em>"
                    )
                </td>
                <td>
                    @(
                        m.MaintenanceType == 1 ? "Revisión por daño" :
                        m.MaintenanceType == 2 ? "Reparación mayor" :
                        m.MaintenanceType == 3 ? "Mantenimiento preventivo" :
                        "—"
                    )
                </td>
                <td>
                    @(
                        m.MaintenanceStatus == 0 ? "Pendiente" :
                        m.MaintenanceStatus == 1 || m.MaintenanceStatus == 2 ? "Finalizado" :
                        "Desconocido"
                    )
                </td>
            </tr>
        }
    </tbody>
</table>
