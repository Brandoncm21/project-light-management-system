@model SetLight.Entidades.Dto.MaintenanceDto

@{
    ViewBag.Title = "Detalles del mantenimiento";

    string tipo = "—";
    switch (Model.MaintenanceType)
    {
        case 1: tipo = "Revisión por daño"; break;
        case 2: tipo = "Reparación mayor"; break;
        case 3: tipo = "Mantenimiento preventivo"; break;
    }

    string estadoTexto = "Desconocido";
    string estadoClase = "badge bg-secondary";

    switch (Model.MaintenanceStatus)
    {
        case 0:
            estadoTexto = "Pendiente";
            estadoClase = "badge bg-warning text-dark";
            break;
        case 1:
            estadoTexto = "Finalizado";
            estadoClase = "badge bg-success";
            break;
        case 2:
            estadoTexto = "Cancelado";
            estadoClase = "badge bg-secondary";
            break;
    }
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">

            <h2 class="fw-bold text-black text-center mb-2">
                Mantenimiento #@Model.MaintenanceId
            </h2>
            <div class="text-center text-muted mb-4">
                Detalles del mantenimiento
            </div>


            <div class="card shadow p-4 border-dark rounded-3">
                <div class="card-body">
                    <!-- Encabezado -->
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h4 class="mb-1">
                                @(!string.IsNullOrEmpty(Model.EquipmentName)
                                    ? Model.EquipmentName
                                    : "Equipo no especificado")
                            </h4>
                            <div class="text-muted small">
                                <span class="me-3">
                                    <i class="bi bi-tools me-1"></i>@tipo
                                </span>
                                <span class="me-3">
                                    <i class="bi bi-calendar-event me-1"></i>
                                    Inicio: @Model.StartDate.ToString("dd/MM/yyyy HH:mm")
                                </span>
                                <span>
                                    <i class="bi bi-flag me-1"></i>
                                    Fin:
                                    @(Model.EndDate.HasValue
                                        ? Model.EndDate.Value.ToString("dd/MM/yyyy HH:mm")
                                        : "—")
                                </span>
                            </div>
                        </div>
                        <span class="@estadoClase">@estadoTexto</span>
                    </div>

                    <hr />

                    <div class="row g-3">
                        <!-- Detalles -->
                        <div class="col-md-7">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Equipo</dt>
                                <dd class="col-sm-8">
                                    @(!string.IsNullOrEmpty(Model.EquipmentName) ? Model.EquipmentName : "—")
                                </dd>

                                <dt class="col-sm-4">Orden de origen</dt>
                                <dd class="col-sm-8">
                                    @if (Model.OrderId.HasValue)
                                    {
                                        @Html.ActionLink(
                                            "#" + Model.OrderId.Value,
                                            "DetallesDevolucion",
                                            "ReturnDetails",
                                            new { orderId = Model.OrderId.Value },
                                            new { @class = "text-decoration-underline text-dark fw-semibold" }
                                        )
                                    }
                                    else
                                    {
                                        @Html.Raw("—")
                                    }
                                </dd>

                                <dt class="col-sm-4">Cliente responsable</dt>
                                <dd class="col-sm-8">
                                    @if (!string.IsNullOrEmpty(Model.ClientName))
                                    {
                                        // Si tenemos también ClientId, hacemos link + modal
                                        if (!string.IsNullOrEmpty(Model.ClientId))
                                        {
                                            var clientIdStr = Model.ClientId;   // string

                                            <a href="#"
                                               data-bs-toggle="modal"
                                               data-bs-target="@("#cltModal_" + clientIdStr)">
                                                @Model.ClientName
                                            </a>

                                            @Html.Action("ModalDetallesCliente", "Client", new { id = clientIdStr })
                                        }
                                        else
                                        {
                                            // No hay ClientId: solo mostramos el nombre (sin modal)
                                            @Model.ClientName
                                        }
                                    }
                                    else
                                    {
                                        @Html.Raw("—")
                                    }
                                </dd>




                                <dt class="col-sm-4">Tipo</dt>
                                <dd class="col-sm-8">@tipo</dd>

                                <dt class="col-sm-4">Comentarios</dt>
                                <dd class="col-sm-8">
                                    @(!string.IsNullOrWhiteSpace(Model.Comments) ? Model.Comments : "—")
                                </dd>

                                <dt class="col-sm-4">Costo</dt>
                                <dd class="col-sm-8">
                                    @(Model.Cost.HasValue ? "$" + Model.Cost.Value.ToString("N2") : "—")
                                </dd>

                                <dt class="col-sm-4">Estado</dt>
                                <dd class="col-sm-8">
                                    <span class="@estadoClase">@estadoTexto</span>
                                </dd>

                                <dt class="col-sm-4">Técnico responsable</dt>
                                <dd class="col-sm-8">
                                    @if (!string.IsNullOrEmpty(Model.TechnicianName))
                                    {
                                        @Model.TechnicianName
                                    }
                                    else if (!string.IsNullOrEmpty(Model.FinalizadoPor))
                                    {
                                        @Model.FinalizadoPor
                                    }
                                    else
                                    {
                                        @Html.Raw("—")
                                    }
                                </dd>
                            </dl>
                        </div>

                        <!-- Evidencia -->
                        <div class="col-md-5">
                            <h6 class="fw-semibold mb-2">Evidencia</h6>

                            @if (!string.IsNullOrEmpty(Model.EvidencePath))
                            {
                                var extension = System.IO.Path.GetExtension(Model.EvidencePath)?.ToLower();

                                if (extension == ".jpg" || extension == ".jpeg" || extension == ".png" || extension == ".gif" || extension == ".webp")
                                {
                                    <div class="border rounded p-2 bg-light text-center">
                                        <img src="@Url.Content(Model.EvidencePath)"
                                             alt="Evidencia"
                                             class="img-fluid rounded shadow-sm"
                                             style="max-height: 260px; object-fit: contain;" />
                                    </div>
                                }
                                else
                                {
                                    <a href="@Url.Content(Model.EvidencePath)"
                                       target="_blank"
                                       class="btn btn-outline-primary btn-sm">
                                        Ver archivo de evidencia
                                    </a>
                                }
                            }
                            else
                            {
                                <p class="text-muted mb-0">
                                    No hay evidencia asociada a este mantenimiento.
                                </p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botones abajo -->
            <div class="text-center mt-4">
                @Html.ActionLink(
                    "Volver a mantenimientos",
                    "Mantenimientos",
                    "ReturnDetails",
                    null,
                    new { @class = "btn btn-dark fw-semibold text-white me-2" }
                )

                @if (Model.MaintenanceStatus == 0)
                {
                    @Html.ActionLink(
                        "Editar",
                        "EditarMantenimiento",
                        "ReturnDetails",
                        new { id = Model.MaintenanceId },
                        new { @class = "btn btn-warning fw-semibold" }
                    )
                }
            </div>

        </div>
    </div>
</div>
