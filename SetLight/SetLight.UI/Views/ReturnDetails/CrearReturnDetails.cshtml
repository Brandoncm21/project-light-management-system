@model SetLight.Abstracciones.ViewModels.EquipmentReturnViewModel

@{
    ViewBag.Title = "Registrar Devolución";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-11">
            <div class="card shadow p-4 border-dark">
                <h2 class="text-center fw-bold text-black mb-3">
                    Registrar devolución - Orden @Model.OrderId
                </h2>
                <h5 class="text-center text-muted mb-4">
                    Cliente: <span class="fw-semibold">@Model.ClientName</span>
                </h5>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <ul class="mb-0">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.OrderId)

                    <div class="table-responsive mt-3">
                        <table class="table table-bordered table-hover text-center align-middle">
                            <thead class="table-dark text-white">
                                <tr>
                                    <th>Equipo</th>
                                    <th>Cantidad alquilada</th>
                                    <th>Cantidad en buen estado</th>
                                    <th>Cantidad dañada</th>
                                    <th>Cantidad faltante</th>
                                    <th>Observaciones</th>
                                    <th>Tipo de mantenimiento</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Items.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            @Html.DisplayFor(m => m.Items[i].EquipmentName)
                                            @Html.HiddenFor(m => m.Items[i].EquipmentId)
                                            @Html.HiddenFor(m => m.Items[i].EquipmentName)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(m => m.Items[i].Quantity)
                                            @Html.HiddenFor(m => m.Items[i].Quantity, new { @class = "qty-total" })
                                        </td>
                                        <td style="min-width: 140px;">
                                            @Html.TextBoxFor(
                                                m => m.Items[i].CantidadBuenas,
                                                new
                                                {
                                                    @class = "form-control border-dark qty-buenas",
                                                    type = "number",
                                                    min = "0",
                                                    max = Model.Items[i].Quantity
                                                })
                                            @Html.ValidationMessageFor(m => m.Items[i].CantidadBuenas, "", new { @class = "text-danger" })
                                        </td>
                                        <td style="min-width: 140px;">
                                            @Html.TextBoxFor(
                                                m => m.Items[i].CantidadDañadas,
                                                new
                                                {
                                                    @class = "form-control border-dark qty-danadas",
                                                    type = "number",
                                                    min = "0",
                                                    max = Model.Items[i].Quantity
                                                })
                                            @Html.ValidationMessageFor(m => m.Items[i].CantidadDañadas, "", new { @class = "text-danger" })
                                        </td>
                                        <td style="min-width: 140px;">
                                            @Html.TextBoxFor(
                                                m => m.Items[i].CantidadFaltante,
                                                new
                                                {
                                                    @class = "form-control border-dark qty-faltantes",
                                                    type = "number",
                                                    min = "0",
                                                    max = Model.Items[i].Quantity
                                                })
                                            @Html.ValidationMessageFor(m => m.Items[i].CantidadFaltante, "", new { @class = "text-danger" })
                                        </td>
                                        <td style="min-width: 180px;">
                                            @Html.TextBoxFor(
                                                m => m.Items[i].Observaciones,
                                                new { @class = "form-control border-dark" })
                                        </td>
                                        <td style="min-width: 200px;">
                                            @Html.DropDownListFor(
                                                m => m.Items[i].MaintenanceType,
                                                new List<SelectListItem> {
                                                    new SelectListItem{ Value="1", Text="Revisión por daño" },
                                                    new SelectListItem{ Value="2", Text="Reparación mayor" },
                                                    new SelectListItem{ Value="3", Text="Mantenimiento preventivo" },
                                                },
                                                "-- Seleccione --",
                                                new { @class = "form-control border-dark" }
                                            )
                                            @Html.ValidationMessageFor(m => m.Items[i].MaintenanceType, "", new { @class = "text-danger" })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="text-center mt-4">
                        <input type="submit" value="Registrar devolución"
                               class="btn btn-danger fw-semibold me-2 text-white" />
                        @Html.ActionLink("Volver al listado", "Index", "RentalOrder",
                            null, new { @class = "btn btn-dark fw-semibold text-white" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rows = document.querySelectorAll("table tbody tr");

            rows.forEach(row => {
                const totalInput = row.querySelector(".qty-total");
                const buenasInput = row.querySelector(".qty-buenas");
                const danadasInput = row.querySelector(".qty-danadas");
                const faltantesInput = row.querySelector(".qty-faltantes");

                if (!totalInput || !buenasInput || !danadasInput || !faltantesInput) {
                    return;
                }

                function onChange(e) {
                    const total = parseInt(totalInput.value || "0");

                    let buenas = parseInt(buenasInput.value || "0");
                    let danadas = parseInt(danadasInput.value || "0");
                    let faltantes = parseInt(faltantesInput.value || "0");

                    // Evitar negativos
                    if (buenas < 0) buenas = 0;
                    if (danadas < 0) danadas = 0;
                    if (faltantes < 0) faltantes = 0;

                    // Si todas las unidades están en buen estado → bloquear el resto
                    if (buenas >= total) {
                        buenas = total;
                        danadas = 0;
                        faltantes = 0;

                        danadasInput.value = 0;
                        faltantesInput.value = 0;
                        danadasInput.disabled = true;
                        faltantesInput.disabled = true;
                    } else {
                        // Habilitar campos si no está todo en buen estado
                        danadasInput.disabled = false;
                        faltantesInput.disabled = false;

                        // Evitar que la suma se pase del total
                        let suma = buenas + danadas + faltantes;
                        if (suma > total) {
                            const target = e.target;
                            let actual = parseInt(target.value || "0");
                            const exceso = suma - total;

                            actual = actual - exceso;
                            if (actual < 0) actual = 0;
                            target.value = actual;

                            // Recalcular valores
                            buenas = parseInt(buenasInput.value || "0");
                            danadas = parseInt(danadasInput.value || "0");
                            faltantes = parseInt(faltantesInput.value || "0");
                        }
                    }

                    buenasInput.value = buenas;
                    danadasInput.value = danadas;
                    faltantesInput.value = faltantes;
                }

                [buenasInput, danadasInput, faltantesInput].forEach(input => {
                    input.addEventListener("input", onChange);
                });
            });
        });
    </script>
}
